# Local environment secrets
.env
.env.local
.env.*.local

# Dependencies and build output
node_modules/
dist/
.vite/
.tmp/
*.tsbuildinfo

# Generated model artifacts are ignored during early development.
# Keep optimized runtime assets in Git LFS or remove these rules once assets stabilize.
public/models/raw/**/*.glb
public/models/raw/**/*.fbx
public/models/raw/**/*.obj
public/models/raw/**/*.stl
public/models/raw/**/*.usdz
public/models/raw/**/*.3mf
public/models/raw/**/*.meshy.json
public/models/cleaned/**/*.glb
public/models/optimized/**/*.glb
public/models/collision/**/*.glb
!public/models/raw/.gitkeep
!public/models/cleaned/.gitkeep
!public/models/optimized/.gitkeep
!public/models/collision/.gitkeep

# Local logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
